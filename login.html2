<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Lynn AI — Sign in</title>
  <link rel="stylesheet" href="style.css" />
</head>
<body class="page-auth">

<div class="auth-wrapper">
  <div class="auth-card">

    <!-- ── Main view ── -->
    <div id="main-view" style="display:flex;flex-direction:column">

      <div class="brand">
        <div class="brand-mark">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"
              d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/>
          </svg>
        </div>
        <div class="brand-name">LYNN</div>
        <div class="brand-tagline">Intelligent. Calm. Always here.</div>
      </div>

      <div class="tabs">
        <button class="tab active" id="tab-login"  onclick="switchAuthTab('login')">Sign in</button>
        <button class="tab"        id="tab-signup" onclick="switchAuthTab('signup')">Create account</button>
      </div>

      <div class="notice" id="notice"></div>

      <div class="fields">
        <div class="field">
          <label for="email">Email</label>
          <input type="email" id="email" placeholder="you@example.com" autocomplete="email" />
        </div>
        <div class="field">
          <label for="password">Password</label>
          <input type="password" id="password" placeholder="••••••••" autocomplete="current-password" />
        </div>
      </div>

      <div class="forgot" id="forgot-wrap">
        <a onclick="showResetView()">Forgot password?</a>
      </div>

      <button class="btn btn-primary" id="submit-btn" data-label="Sign in" onclick="handleAuthSubmit()">
        Sign in
      </button>

      <div class="divider">or</div>

      <button class="btn-oauth" onclick="handleGoogleSignIn()">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
        </svg>
        Continue with Google
      </button>

      <p class="auth-footer" id="footer-text">
        Don't have an account? <a href="signup.html">Create one</a>
      </p>

    </div>

    <!-- ── Reset password view ── -->
    <div id="reset-view" style="display:none;flex-direction:column">

      <button class="back-btn" onclick="showMainView()">
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" width="16" height="16">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        Back to sign in
      </button>

      <div class="brand" style="margin-bottom:24px">
        <div class="brand-name" style="font-size:19px;letter-spacing:0.08em">Reset password</div>
        <div class="brand-tagline" style="margin-top:8px">We'll send a link to your inbox.</div>
      </div>

      <div class="notice" id="reset-notice"></div>

      <div class="fields">
        <div class="field">
          <label for="reset-email">Email</label>
          <input type="email" id="reset-email" placeholder="you@example.com" autocomplete="email" />
        </div>
      </div>

      <button class="btn btn-primary" id="reset-btn" data-label="Send reset link" onclick="handleReset()">
        Send reset link
      </button>

      <p class="auth-footer">Check your spam folder if you don't see it.</p>

    </div>

  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script src="script.js"></script>
</body>
</html>
